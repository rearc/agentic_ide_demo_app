// =============================================================================
// settings.example.jsonc  —  A GUIDED TOUR of Claude Code settings
// -----------------------------------------------------------------------------
// This is a TEACHING CATALOG, not a live config. Claude Code does NOT load this
// file (it only reads settings.json / settings.local.json). It exists so we can
// walk through what's available and what each key does.
//
// ⚠️  IMPORTANT: real `.claude/settings.json` is STRICT JSON — it does NOT
//     support `//` comments. The comments here are for humans only. To annotate
//     a real settings file, use a `_comment` sibling key (Claude Code ignores
//     unknown keys) or keep the notes in a separate doc.
//
// ⚠️  markers below = keys that CHANGE RUNTIME BEHAVIOR (would affect a live
//     session). ✅ = cosmetic / safe. Verify exact keys+values against the live
//     docs (code.claude.com/docs/en/settings.md) before relying on them.
// =============================================================================
{
  // ---------------------------------------------------------------------------
  // PERMISSIONS  ⚠️  — posture: what the agent may attempt. deny always wins.
  // Rule form: Tool(pattern) — e.g. Bash(npm run *), Read(./src/**), Edit(./x),
  // WebFetch(domain:*.github.com), mcp__server__tool, Agent(Explore).
  // ---------------------------------------------------------------------------
  "permissions": {
    "allow": [                       // pre-approved — run without prompting
      "Read(./**)",
      "Bash(npm run *)",
      "Bash(git status)",
      "Bash(git log *)"
    ],
    "ask": [                         // always confirm before running
      "Bash(git push *)",
      "Write(./backend/migrations/**)"
    ],
    "deny": [                        // blocked outright (highest precedence)
      "Read(./secrets/**)",
      "Read(./.env)",
      "Bash(git push --force *)"
    ],
    "additionalDirectories": [       // grant file access OUTSIDE the repo root
      "~/shared-design-assets"
    ]
  },

  // ---------------------------------------------------------------------------
  // MCP SERVER CONTROL  ⚠️  (allow/deny lists — often managed org-wide)
  // ---------------------------------------------------------------------------
  "allowedMcpServers": [],           // ⚠️ if non-empty, ONLY these MCP servers load (whitelist). Empty = no restriction.
  "deniedMcpServers": [],            // ⚠️ blocklist of MCP servers to refuse. e.g. [{"serverName":"filesystem"}]

  // ---------------------------------------------------------------------------
  // MEMORY & CONTEXT
  // ---------------------------------------------------------------------------
  "autoMemoryEnabled": true,         // ⚠️ Claude writes its own per-repo memory (MEMORY.md) as it learns
  "autoMemoryDirectory": "~/.claude/projects",  // ✅ where auto-memory is stored (default shown)
  "claudeMdExcludes": [              // ⚠️ glob patterns of CLAUDE.md / rules files to NOT auto-load
    "**/vendor/**/CLAUDE.md"         //     (handy in monorepos where ancestor CLAUDE.md files are irrelevant)
  ],
  "autoCompactEnabled": true,        // ⚠️ auto-summarize the conversation when the context window fills

  // ---------------------------------------------------------------------------
  // AUTO MODE  ⚠️  — the classifier that auto-approves safe actions without prompts
  // ---------------------------------------------------------------------------
  "autoMode": {
    // autoMode configures the classifier that auto-approves safe actions when auto mode is on.
    // KEY IDEA: unlike permissions (exact Tool(pattern) matches), auto-mode allow/soft_deny/hard_deny
    // accept PLAIN-ENGLISH PROSE — the classifier reads and applies these natural-language rules.
    "environment": ["$defaults"],    // trusted-infra baseline
    "soft_deny": [                   // ⚠️ prose the classifier leans toward blocking / prompting on
      "Anything that deletes data, drops database tables, or wipes migrations",
      "Editing deployment, CI/CD, or production config files"
    ]
  },
  "disableAutoMode": "disable",      // ⚠️ (managed-only) org-wide kill switch for auto mode. Omit the key to allow it.

  // ---------------------------------------------------------------------------
  // HOOKS  ⚠️  — code (or a model) wired to lifecycle events.
  // Rules GUIDE (model may comply); hooks ENFORCE / OBSERVE / AUTOMATE (run regardless of the model).
  // Shape: "hooks": { "<Event>": [ { "matcher": "<pat>", "hooks": [ {"type":"command","command":"..."} ] } ] }
  //   • matcher = which instances fire (tool name, agent type, source, ...). Some events take NO matcher (fires always).
  //   • A handler's EXIT CODE / RESPONSE is the primary control (exit 2 does something DIFFERENT per event — noted per-event below).
  //   • Richer control via JSON on stdout (decision/reason, permissionDecision, additionalContext, updatedInput, ...).
  //
  //   FIVE HANDLER TYPES (the `type` field). We TEACH the first three; the last two are "if asked":
  //     ▸ "command"  — DETERMINISTIC. Shell command; JSON payload on stdin, control via exit code + stdout JSON.  ← our guard-shell/audit/auto-lint
  //     ▸ "http"     — DETERMINISTIC (external). POSTs the payload to a URL; the 2xx JSON response IS the decision.
  //                     fields: url(req), headers, allowedEnvVars, timeout(600s), statusMessage, if.
  //     ▸ "prompt"   — MODEL-IN-THE-LOOP. Sends `prompt` (with $ARGUMENTS = the payload JSON) to a Claude model for a
  //                     single-turn yes/no decision. fields: prompt(req), model(fast default), timeout(30s), statusMessage, if.
  //     ▸ "mcp_tool" — calls a tool on a connected MCP server. fields: server(req), tool(req), input(${...} subst), timeout.
  //     ▸ "agent"    — EXPERIMENTAL. Spawns a subagent that can Read/Grep/Glob to VERIFY before deciding. fields: prompt(req), model, timeout(60s).
  //   TEACHING POINT: command/http = deterministic ("enforce without model compliance"); prompt/agent = model judgment
  //     (flexible + nuanced, but reintroduce the model — use for ADVISORY checks, not hard guarantees).
  //   PROSE BACK TO THE AGENT: `additionalContext` (PreToolUse/PostToolUse/UserPromptSubmit/SessionStart/Stop/...) injects
  //     advisory text as a system reminder the agent then considers — distinct from `reason`/`permissionDecisionReason`
  //     which accompany an allow/deny/block DECISION.
  //
  // Docs: https://code.claude.com/docs/en/hooks.md
  // NOTE: only the 3 handlers marked ✅REAL below actually run in this repo (they live in settings.json).
  //       Everything else here is ILLUSTRATIVE — placeholder commands to show the event + its wiring.
  //       Runnable command/http/prompt SHOWCASES live in a separate opt-in file (see settings.hooks-showcase.json).
  // ---------------------------------------------------------------------------
  "disableAllHooks": false,          // ⚠️ true = turn OFF every hook (would kill our guard-shell/audit/auto-lint demo!)

  "hooks": {

    // === WORKHORSES — the events you'll actually write 90% of the time =======

    // matcher: tool name (Bash, Edit, mcp__server__tool) | exit2: BLOCKS the tool call | ctrl: permissionDecision(allow|deny|ask|defer), updatedInput, additionalContext
    // use: guardrails (block dangerous commands), rewrite tool inputs, escalate to a human
    // One event can carry MULTIPLE handlers of DIFFERENT types — here: command (x2, real) + http + prompt (illustrative).
    "PreToolUse": [
      { "matcher": "Bash",
        "hooks": [ { "type": "command", "command": ".claude/hooks/rearc-workshop-demo-kit/scripts/hooks/guard-shell.sh" } ] },  // ✅REAL — blocks rm -rf / git reset --hard / DROP TABLE via exit 2
      { "matcher": ".*",
        "hooks": [ { "type": "command", "command": ".claude/hooks/rearc-workshop-demo-kit/scripts/hooks/audit.sh" } ] },        // ✅REAL — logs EVERY tool call (observe); exit 0
      { "matcher": "Bash",                                                                                                       // ILLUSTRATIVE — "http" type: POST payload to a local policy service; its 2xx JSON is the decision
        "hooks": [ { "type": "http", "url": "http://localhost:8080/hooks/pre-tool-use", "timeout": 30,
                     "headers": { "Authorization": "Bearer $POLICY_TOKEN" }, "allowedEnvVars": ["POLICY_TOKEN"] } ] },
      { "matcher": "Bash",                                                                                                       // ILLUSTRATIVE — "prompt" type: a fast model judges the command; $ARGUMENTS = the payload JSON
        "hooks": [ { "type": "prompt", "timeout": 30,
                     "prompt": "You are a shell-safety gate. Given this PreToolUse payload, decide if the command is destructive or touches production. $ARGUMENTS" } ] }
    ],

    // matcher: tool name | exit2: shows stderr to Claude (can prompt a retry) | ctrl: updatedToolOutput (rewrite what Claude sees), decision:block, additionalContext
    // use: auto-format / lint after edits, inject validation of a tool's result
    "PostToolUse": [
      { "matcher": "Edit|Write|MultiEdit",
        "hooks": [ { "type": "command", "command": ".claude/hooks/rearc-workshop-demo-kit/scripts/hooks/auto-lint.sh" } ] }      // ✅REAL — eslint/ruff --fix after edits (automate); exit 0, fail-open
    ],

    // matcher: NONE | exit2: BLOCKS the prompt (Claude never sees it) | ctrl: decision:block+reason, additionalContext (prepended to the prompt)
    // use: inject dynamic context (ticket #, current branch), validate/rewrite prompts, gate certain asks
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "echo '(illustrative) inject repo context here'" } ] }
    ],

    // matcher: startup | resume | clear | compact | exit2: stderr to user only (no block) | ctrl: additionalContext, initialUserMessage, sessionTitle, watchPaths, reloadSkills
    // use: load project context at session start, set the session title, seed a first message
    "SessionStart": [
      { "matcher": "startup",
        "hooks": [ { "type": "command", "command": "echo '(illustrative) load standards / open PRs into context'" } ] }
    ],

    // matcher: NONE | exit2: PREVENTS Claude from stopping (forces another turn) | ctrl: decision:block+reason, additionalContext
    // use: verification gate — fact-check / test the output before the turn is allowed to end
    "Stop": [
      { "hooks": [ { "type": "command", "command": "echo '(illustrative) run tests; block stop if red'" } ] }
    ],

    // === TOOL / PERMISSION VARIANTS — finer-grained control around a tool call

    // matcher: tool name | exit2: DENIES the permission | ctrl: decision.behavior, updatedInput | use: auto-approve/deny in the permission dialog by context
    "PermissionRequest": [
      { "matcher": "Bash", "hooks": [ { "type": "command", "command": "echo '(illustrative) auto-approve safe reads'" } ] }
    ],
    // matcher: tool name | exit2: ignored | ctrl: retry:true | use: log auto-mode denials, notify an admin, retry with an explanation
    "PermissionDenied": [
      { "matcher": ".*", "hooks": [ { "type": "command", "command": "echo '(illustrative) log the denied call'" } ] }
    ],
    // matcher: tool name | exit2: shows stderr to Claude | ctrl: decision:block, reason | use: coach a recovery strategy after a tool errors
    "PostToolUseFailure": [
      { "matcher": ".*", "hooks": [ { "type": "command", "command": "echo '(illustrative) suggest a fix on failure'" } ] }
    ],

    // === SUBAGENTS ============================================================

    // matcher: agent type | exit2: stderr to user only | ctrl: additionalContext | use: track/brief a spawned subagent
    "SubagentStart": [
      { "matcher": ".*", "hooks": [ { "type": "command", "command": "echo '(illustrative) note subagent spawn'" } ] }
    ],
    // matcher: agent type | exit2: PREVENTS the subagent stopping | ctrl: decision:block+reason, additionalContext | use: gate subagent completion, aggregate results
    "SubagentStop": [
      { "matcher": ".*", "hooks": [ { "type": "command", "command": "echo '(illustrative) verify subagent result'" } ] }
    ],

    // === SESSION / TURN LIFECYCLE ============================================

    // matcher: why the session ended | exit2: stderr to user only | ctrl: side effects only | use: archive the transcript, notify an external system, cleanup
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "echo '(illustrative) archive transcript'" } ] }
    ],
    // matcher: error type (rate_limit, overloaded, ...) | exit2: ignored | ctrl: side effects only | use: backoff / notify on an API-error turn end
    "StopFailure": [
      { "matcher": ".*", "hooks": [ { "type": "command", "command": "echo '(illustrative) alert on rate limit'" } ] }
    ],

    // === CONTEXT MANAGEMENT ==================================================

    // matcher: manual | auto | exit2: BLOCKS compaction | ctrl: decision:block+reason | use: prevent compaction mid-debug, or snapshot context first
    "PreCompact": [
      { "matcher": "auto", "hooks": [ { "type": "command", "command": "echo '(illustrative) snapshot before compaction'" } ] }
    ],
    // matcher: manual | auto | exit2: stderr to user only | ctrl: side effects only | use: log compaction, measure how much was dropped
    "PostCompact": [
      { "matcher": "auto", "hooks": [ { "type": "command", "command": "echo '(illustrative) log compaction size'" } ] }
    ],

    // === FILE / CONFIG / DIRECTORY WATCHERS ==================================

    // matcher: literal filenames (no regex) | exit2: stderr to user only | ctrl: side effects only | use: react to an external edit of a watched file
    "FileChanged": [
      { "matcher": "package.json", "hooks": [ { "type": "command", "command": "echo '(illustrative) deps changed on disk'" } ] }
    ],
    // matcher: config source (user|project|local|plugin|skill) | exit2: BLOCKS the config change | ctrl: decision:block+reason | use: validate/forbid risky settings edits
    "ConfigChange": [
      { "matcher": "project", "hooks": [ { "type": "command", "command": "echo '(illustrative) reject forbidden permission edits'" } ] }
    ],
    // matcher: load reason | exit2: ignored | ctrl: side effects only | use: audit when CLAUDE.md / a rule file gets loaded into context
    "InstructionsLoaded": [
      { "hooks": [ { "type": "command", "command": "echo '(illustrative) audit instruction load'" } ] }
    ],
    // matcher: NONE | exit2: stderr to user only | ctrl: side effects only | use: log directory transitions
    "CwdChanged": [
      { "hooks": [ { "type": "command", "command": "echo '(illustrative) log cwd change'" } ] }
    ],

    // === WORKTREES ===========================================================

    // matcher: NONE | exit2: any non-zero exit FAILS creation | ctrl: return a custom worktreePath on stdout | use: put worktrees on a custom path / external tool
    "WorktreeCreate": [
      { "hooks": [ { "type": "command", "command": "echo '(illustrative) emit custom worktree path'" } ] }
    ],
    // matcher: NONE | exit2: failures logged at debug only | ctrl: side effects only | use: archive a worktree before it's removed
    "WorktreeRemove": [
      { "hooks": [ { "type": "command", "command": "echo '(illustrative) archive worktree pre-remove'" } ] }
    ]
  },

  // ---------------------------------------------------------------------------
  // MODEL / REASONING
  // ---------------------------------------------------------------------------
  "effortLevel": "medium",           // ⚠️ reasoning depth: low | medium | high | xhigh | max (speed vs quality)

  // ---------------------------------------------------------------------------
  // ENVIRONMENT  ⚠️  — env vars injected into every session/subprocess
  // ---------------------------------------------------------------------------
  "env": {
    // ⚠️ affects tool execution. Common uses: telemetry/audit export, feature flags.
    "EXAMPLE_VAR": "example-value"
  },

  // ---------------------------------------------------------------------------
  // SKILL DISCOVERY
  // ---------------------------------------------------------------------------
  "skillListingBudgetFraction": 0.15, // ⚠️ fraction of context spent listing available skills to Claude.
                                      //     Lower = cheaper but may hide skills from discovery.
  "skillListingMaxDescChars": 500,    // ✅ max chars shown per skill description in the listing (display only)

  // ---------------------------------------------------------------------------
  // SHELL & PLANS
  // ---------------------------------------------------------------------------
  "defaultShell": "zsh",             // ⚠️ shell used for `!` passthrough commands: bash | zsh | fish | powershell
  "plansDirectory": "~/.claude/plans", // ✅ where /plan output is saved

  // ---------------------------------------------------------------------------
  // HOUSEKEEPING
  // ---------------------------------------------------------------------------
  "cleanupPeriodDays": 365,          // ✅ days before old session files are deleted. Set HIGH so this repo's
                                     //     workshop sessions aren't reaped (default is 30).
  "feedbackSurveyRate": 0,           // ✅ probability (0–1) of a feedback survey. 0 = never bug attendees.
  "companyAnnouncements": [          // ✅ messages shown at session start
    "Welcome to the workshop!"
  ],

  // ---------------------------------------------------------------------------
  // UI / COSMETIC  (✅ all safe — presentation only)
  // ---------------------------------------------------------------------------
  "theme": "auto",                   // ✅ color scheme: auto | light | dark
  "language": "en",                  // ✅ UI language (en, es, fr, de, ja, ...)
  "outputStyle": "auto",             // ✅ rendering: auto | fullscreen | classic. Requires restart to change.
                                     //     Docs: https://code.claude.com/docs/en/fullscreen.md
  "statusLine": {                    // ✅ custom status line = the rearc/base toolkit METER
    "type": "command",               //     (context-window %, 5h/weekly rate-limit burn, session cost).
    "command": ".claude/statusline.sh" //   Copy from ai-toolkit/packages/rearc-base/scripts/statusline.sh (needs jq).
  },
  "showThinkingSummaries": true,     // ✅ show Claude's thinking summaries (when extended thinking is on)
  "showTurnDuration": true,          // ✅ show elapsed time per turn
  "autoScrollEnabled": true,         // ✅ auto-scroll output in fullscreen mode
  "spinnerTipsEnabled": true,        // ✅ show rotating tips while Claude works
  "spinnerTipsOverride": [           // ✅ replace the default tips with your own
    "Tip: /memory shows what Claude has loaded.",
    "Tip: hooks enforce; rules only guide."
  ],
  "spinnerVerbs": [                  // ✅ the "Claude is ___..." words. Ours = workshop-flavored fun.
    "vibing", "conjuring", "yak-shaving", "overthinking",
    "summoning", "bikeshedding", "caffeinating"
  ],
  "askUserQuestionTimeout": "5m",    // ✅ how long a question dialog waits before auto-continuing
  "verbose": false                   // ⚠️(mild) true = verbose logging (same as --verbose / CLAUDE_CODE_VERBOSE);
                                     //     shows every tool call in full. Handy for the subagent-read-only proof.
}
