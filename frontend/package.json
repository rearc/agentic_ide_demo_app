{
  "name": "dashboard-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check:node": "node -e \"var m=+process.versions.node.split('.')[0]; if(m<22){console.error('\\n[STOP] Node '+process.version+' detected - this test suite requires Node >=22.\\n        On Node 20 the suite fails with ERR_REQUIRE_ESM and reports ZERO tests,\\n        which looks like \\'no tests were written\\' but is a Node version problem.\\n        Fix: nvm use   (see frontend/.nvmrc)\\n'); process.exit(1)}\"",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pretest": "npm run check:node",
    "test": "vitest",
    "pretest:run": "npm run check:node",
    "test:run": "vitest run",
    "pretest:ui": "npm run check:node",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^2.2.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/ui": "^4.1.10",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.2.2",
    "vite": "^6.4.1",
    "vitest": "^4.1.10"
  }
}
