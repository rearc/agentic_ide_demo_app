{
  "permissions": {
    "deny": [
      "Read(./secrets/**)",
      "Read(./docs/reference/claude_md_examples/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/rearc-workshop-demo-kit/scripts/hooks/audit.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/rearc-workshop-demo-kit/scripts/hooks/guard-shell.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/rearc-workshop-demo-kit/scripts/hooks/auto-lint.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline.sh"
  }
}
